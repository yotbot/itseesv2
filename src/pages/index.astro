---
import Layout from '../layouts/Layout.astro';
import FloatingDots from '../components/FloatingDots.astro';
import HeroSection from '../components/HeroSection.astro';
import AboutSection from '../components/AboutSection.astro';
import ProcessSection from '../components/ProcessSection.astro';
import FooterSection from '../components/FooterSection.astro';
---

<Layout title="itsees | Full-Service Web Development">
  <!-- Floating dots that animate throughout the page -->
  <FloatingDots />

  <!-- Main content sections -->
  <main>
    <HeroSection />
    <AboutSection />
    <ProcessSection />

    <FooterSection />
  </main>
</Layout>

<style>
  /* Ensure proper scroll height for animations */
  main {
    min-height: 500vh;
  }
</style>
