---
// AboutSection.astro - Full-service web development intro with service cards
interface Props {
  titleLine1: string;
  titleLine2: string;
  subtitle: string;
  services: { title: string; description: string }[];
}

const { titleLine1, titleLine2, subtitle, services: serviceTexts } = Astro.props;

const icons = [
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path></svg>`,
  `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>`,
];

const services = serviceTexts.map((s, i) => ({ ...s, icon: icons[i] }));
---

<section id="about" class="relative min-h-screen py-40 transition-colors duration-700">
  <div class="section-container relative z-20">
    <!-- Main headline -->
    <div class="mb-24">
      <h2 class="about-title font-bold text-itsees-text leading-none tracking-tighter mb-8" style="font-size: clamp(3rem, 11vw, 11rem);">
        {titleLine1}<br />{titleLine2}
      </h2>
      <p class="text-sm md:text-base text-itsees-text/80 max-w-xs leading-relaxed about-subtitle uppercase tracking-widest">
        {subtitle}
      </p>
    </div>

    <!-- Service cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {services.map((service) => (
        <div
          class="service-card group"
        >
          <div class="text-itsees-text/20 mb-5 shrink-0" set:html={service.icon} />
          <h3 class="text-2xl md:text-3xl font-bold text-itsees-text mb-3 leading-tight">
            {service.title}
          </h3>
          <p class="text-sm text-itsees-text/60 leading-relaxed">
            {service.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    // Animate title
    gsap.from('.about-title', {
      opacity: 0,
      y: 50,
      scrollTrigger: {
        trigger: '#about',
        start: 'top 80%',
        end: 'top 50%',
        scrub: 1,
      },
    });

    // Animate subtitle
    gsap.from('.about-subtitle', {
      opacity: 0,
      y: 30,
      scrollTrigger: {
        trigger: '#about',
        start: 'top 70%',
        end: 'top 40%',
        scrub: 1,
      },
    });

    // Animate service cards
    gsap.utils.toArray('.service-card').forEach((card) => {
      gsap.from(card as Element, {
        opacity: 0,
        y: 40,
        scrollTrigger: {
          trigger: card as Element,
          start: 'top 85%',
          end: 'top 65%',
          scrub: 1,
        },
      });
    });
  });
</script>

<style>
  .service-card {
    @apply bg-transparent rounded-2xl p-6 md:p-10 border-2 border-black;
  }
</style>
